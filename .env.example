# ============================================================================
# mcp-yammer-engage — environment configuration
# ============================================================================
# Copy this file to `.env` and fill in your values. NEVER commit `.env`.
#
# See README.md §"Azure App Registration" for how to obtain the IDs below.

# ---- Required: Entra ID app registration --------------------------------
# Application (client) ID from your Entra public-client app registration.
#
# Tip: if you can't create a new App Registration (e.g. Microsoft-internal
# users without a Service Tree ID), you can reuse an existing public client.
# See README § "Reusing an existing Microsoft public client ID".
#   Microsoft Azure CLI:        04b07795-8ddb-461a-bbee-02f9e1bf7b46
#   Microsoft Azure PowerShell: 1950a258-227b-4e31-a9cf-717495945fc8
#   Microsoft Graph PowerShell: 14d82eec-204b-4c2f-b7e8-296a70dab67e
AZURE_CLIENT_ID=

# Directory (tenant) ID from the same app registration.
# Use "common" only if the app supports multi-tenant, or "organizations"
# when reusing a multi-tenant Microsoft public client.
AZURE_TENANT_ID=

# ---- Optional: Yammer / Engage scopes -----------------------------------
# Space-separated list. Default is the minimal Yammer delegated scope.
# Adjust per Phase 0.5 spike findings if your tenant requires broader scopes
# (e.g. Community.Read.All, EngagementConversation.ReadWrite.All,
# Storyline.ReadWrite.All — all delegated).
# YAMMER_SCOPES=https://api.yammer.com/user_impersonation

# ---- Optional: auth mode ------------------------------------------------
# "device_code" (default, recommended for MCP/stdio) or "interactive".
# Interactive opens a browser and listens on a localhost port; works only
# when the user is running the server directly, not when launched by an
# MCP client over stdio.
# AUTH_MODE=device_code

# ---- Optional: HTTP behavior --------------------------------------------
# MAX_CONCURRENT_REQUESTS=2
# REQUEST_TIMEOUT_MS=30000

# ---- Optional: logging --------------------------------------------------
# pino levels: trace, debug, info, warn, error, fatal
# LOG_LEVEL=info

# ---- Optional: cache & audit location -----------------------------------
# Override the OS-default cache directory. Useful for per-agent dev runs
# (parallel agents MUST use different cache dirs to avoid MSAL corruption).
# Defaults: %LOCALAPPDATA%\mcp-yammer-engage on Windows,
#           ~/Library/Application Support/mcp-yammer-engage on macOS,
#           $XDG_CACHE_HOME/mcp-yammer-engage on Linux.
# TOKEN_CACHE_DIR=
